{
  "realm": "spring-realm",
  "enabled": true,
  "displayName": "Spring Realm",
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "spring-client",
      "name": "Spring Boot Login Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "spring-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8081/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:8081"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8081/*"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "spring-api",
      "name": "Spring Boot Resource Server",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "secret": "spring-api-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "USER"
      },
      {
        "name": "ADMIN"
      },
      {
        "name": "PRUEBA"
      }
    ]
  },
  "users": [
    {
      "username": "alberto",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alberto",
      "lastName": "Velasquez",
      "email": "alberto@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "123456",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER",
        "ADMIN"
      ]
    },
    {
      "username": "nuevousuario",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Marco",
      "lastName": "Perez",
      "email": "marco@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "123abc",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER",
        "ADMIN"
      ]
    }
  ]
}